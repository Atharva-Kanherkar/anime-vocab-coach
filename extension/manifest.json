{
  "manifest_version": 3,
  "name": "AnimeVocab: Learn Japanese from Anime — Netflix, Crunchyroll & YouTube",
  "short_name": "AnimeVocab",
  "version": "0.5.1",
  "description": "Learn Japanese from the anime you watch, even before you can read it — one word per line, in romaji, with spaced repetition.",
  "permissions": ["storage", "tabCapture", "offscreen", "scripting", "alarms", "webNavigation"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.netflix.com/*",
    "*://*.crunchyroll.com/*",
    "https://api.openai.com/*",
    "https://api.animevocab.com/*",
    "https://animevocab.com/*"
  ],
  "icons": { "16": "icons/icon16.png", "32": "icons/icon32.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "AnimeVocab",
    "default_icon": { "16": "icons/icon16.png", "32": "icons/icon32.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*", "*://*.netflix.com/*"],
      "js": ["vendor/kuromoji.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["*://*.crunchyroll.com/*"],
      "js": ["vendor/kuromoji.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["page/youtube-main.js"],
      "run_at": "document_idle",
      "all_frames": false,
      "world": "MAIN"
    },
    {
      "matches": ["*://*.netflix.com/*"],
      "js": ["page/netflix-main.js"],
      "run_at": "document_idle",
      "all_frames": false,
      "world": "MAIN"
    },
    {
      "matches": ["https://animevocab.com/*"],
      "js": ["sync-bridge.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["kuromoji/dict/*", "data/dictionary.json"],
      "matches": ["*://*.youtube.com/*", "*://*.netflix.com/*", "*://*.crunchyroll.com/*"]
    }
  ]
}
