{
  "manifest_version": 3,
  "name": "Anime Vocab Coach",
  "version": "0.2.0",
  "description": "Learn Japanese from the anime you watch — even if you can't read it yet. Watches with you, pauses on words worth learning, tracks progress.",
  "permissions": ["storage", "tabCapture", "offscreen", "scripting"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.netflix.com/*",
    "*://*.crunchyroll.com/*",
    "https://api.openai.com/*"
  ],
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Anime Vocab Coach",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*", "*://*.netflix.com/*"],
      "js": [
        "vendor/kuromoji.js",
        "src/log.js",
        "src/romaji.js",
        "src/storage.js",
        "src/dictionary.js",
        "src/tokenizer.js",
        "src/scoring.js",
        "src/overlay.js",
        "src/adapters/youtube.js",
        "src/adapters/netflix.js",
        "src/adapters/generic.js",
        "src/main.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["*://*.crunchyroll.com/*"],
      "js": [
        "vendor/kuromoji.js",
        "src/log.js",
        "src/romaji.js",
        "src/storage.js",
        "src/dictionary.js",
        "src/tokenizer.js",
        "src/scoring.js",
        "src/overlay.js",
        "src/adapters/youtube.js",
        "src/adapters/netflix.js",
        "src/adapters/generic.js",
        "src/main.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["page/youtube-main.js"],
      "run_at": "document_idle",
      "all_frames": false,
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["kuromoji/dict/*", "data/dictionary.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
