{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "animevocab",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-07-03",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "kv_namespaces": [
    {
      "binding": "AVC_SYNC_KV",
      "id": "8e67f3701aa04195975a583cc59d8425"
    }
  ],
  // AI coach (issue #13). OPENAI_API_KEY is a Worker secret, not a var:
  //   npx wrangler secret put OPENAI_API_KEY
  // gpt-4.1-nano is the cheapest capable model ($0.10/$0.40 per 1M tokens as of
  // Jul 2026): a coach call costs ~$0.00014. Limits are per Clerk user per month.
  //
  // Free launch: until AI_FREE_LAUNCH_UNTIL, every signed-in account gets all AI
  // features at LAUNCH_AI_CALLS_PER_MONTH (no Dodo/plan gating). Still capped so a
  // launch cannot blow the budget. After the date, the free/pro limits apply.
  "vars": {
    "AI_COACH_MODEL": "gpt-4.1-nano",
    "FREE_AI_CALLS_PER_MONTH": "40",
    "PRO_AI_CALLS_PER_MONTH": "150",
    "MAX_AI_CALLS_PER_MONTH": "600",
    "LAUNCH_AI_CALLS_PER_MONTH": "40",
    "AI_FREE_LAUNCH_UNTIL": "2026-09-01T00:00:00.000Z",
    // Manga Studio (see docs/unit-economics.md "Manga Studio"). Free, capped
    // per user per month; image quality is the main cost knob.
    "STUDIO_CREATIONS_PER_MONTH": "5",
    "STUDIO_SCRIPT_MODEL": "gpt-4.1-mini",
    "STUDIO_IMAGE_MODEL": "gpt-image-2",
    "STUDIO_IMAGE_QUALITY": "medium"
  },
  "observability": {
    "enabled": true
  }
}
