NEXT_PUBLIC_API_BASE=https://api.animevocab.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key
CLERK_SECRET_KEY=sk_test_your_key
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/app
# AI coach (issue #13). In production set OPENAI_API_KEY as a Worker secret instead.
OPENAI_API_KEY=sk-your-openai-key
AI_COACH_MODEL=gpt-4.1-nano
FREE_AI_CALLS_PER_MONTH=40
PRO_AI_CALLS_PER_MONTH=150
MAX_AI_CALLS_PER_MONTH=600

# Resend (production: RESEND_API_KEY as Worker secret; FROM/REPLY_TO are plaintext vars).
RESEND_API_KEY=re_your_key
EMAIL_FROM=Anime Vocab <atharva@animevocab.com>
EMAIL_REPLY_TO=atharvakanherkar25@gmail.com

# Meta Pixel (Instagram/Facebook ads) — optional
NEXT_PUBLIC_META_PIXEL_ID=
